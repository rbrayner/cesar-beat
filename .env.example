# Copy to .env (gitignored). Empty values fall back to defaults in .justfile / compose.defectdojo.yml.

# Dependency-Track
DT_PASS=Lab1234!

# NIST NVD API key — speeds up the NVD mirror inside DT. Optional.
# Request at: https://nvd.nist.gov/developers/request-an-api-key
NVD_KEY=

# DefectDojo
DD_USER=admin
DD_PASS=Lab1234!

# Django SECRET_KEY (HMAC seed) and AES key for credential storage in DD.
# Generate with: openssl rand -base64 32
DD_SECRET_KEY=
DD_CREDENTIAL_AES_256_KEY=
